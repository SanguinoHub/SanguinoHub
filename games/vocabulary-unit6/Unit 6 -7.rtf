let userAnswers = new Array(quizData.length).fill(-1);\
let submitted = false;\
\
function buildQuiz() \{\
    const container = document.getElementById('quizBody');\
    let html = '';\
    let currentSection = '';\
\
    quizData.forEach((item, idx) => \{\
        if (item.section && item.section !== currentSection) \{\
            currentSection = item.section;\
            html += `<div class="section-title">$\{currentSection\}</div>`;\
        \}\
        const letters = ['A', 'B', 'C', 'D'];\
        html += `<div class="question" id="q$\{idx\}">`;\
        html += `<div class="question-text">$\{item.q\}</div>`;\
        html += `<ul class="options">`;\
        item.options.forEach((opt, oi) => \{\
            html += `<li onclick="selectOption($\{idx\}, $\{oi\})" id="q$\{idx\}o$\{oi\}">\
                        <span class="letter">$\{letters[oi]\}</span> $\{opt\}\
                     </li>`;\
        \});\
        html += `</ul>`;\
        html += `<div class="feedback" id="fb$\{idx\}"></div>`;\
        html += `</div>`;\
    \});\
\
    container.innerHTML = html;\
\}\
\
function selectOption(qIdx, oIdx) \{\
    if (submitted) return;\
    userAnswers[qIdx] = oIdx;\
\
    const q = document.getElementById(`q$\{qIdx\}`);\
    const opts = q.querySelectorAll('.options li');\
    opts.forEach((li, i) => \{\
        li.classList.toggle('selected', i === oIdx);\
    \});\
\
    updateProgress();\
\}\
\
function updateProgress() \{\
    const answered = userAnswers.filter(a => a !== -1).length;\
    const total = quizData.length;\
    const pct = Math.round((answered / total) * 100);\
    document.getElementById('progressFill').style.width = pct + '%';\
    document.getElementById('progressText').textContent = `$\{pct\}% complete`;\
\}\
\
function submitQuiz() \{\
    const unanswered = userAnswers.filter(a => a === -1).length;\
    if (unanswered > 0) \{\
        if (!confirm(`You have $\{unanswered\} unanswered question(s). Submit anyway?`)) return;\
    \}\
\
    submitted = true;\
    let score = 0;\
    const catScores = \{\};\
\
    quizData.forEach((item, idx) => \{\
        const cat = item.cat;\
        if (!catScores[cat]) catScores[cat] = \{ correct: 0, total: 0 \};\
        catScores[cat].total++;\
\
        const qDiv = document.getElementById(`q$\{idx\}`);\
        const fb = document.getElementById(`fb$\{idx\}`);\
        const correct = item.answer;\
        const user = userAnswers[idx];\
\
        if (user === correct) \{\
            score++;\
            catScores[cat].correct++;\
            qDiv.classList.add('correct');\
            fb.className = 'feedback correct show';\
            fb.textContent = '\uc0\u9989  Correct!';\
            if (user !== -1) document.getElementById(`q$\{idx\}o$\{user\}`).classList.add('correct-answer');\
        \} else \{\
            qDiv.classList.add('incorrect');\
            fb.className = 'feedback incorrect show';\
            fb.textContent = `\uc0\u10060  Incorrect. The correct answer is: $\{item.options[correct]\}`;\
            if (user !== -1) document.getElementById(`q$\{idx\}o$\{user\}`).classList.add('wrong-answer');\
            document.getElementById(`q$\{idx\}o$\{correct\}`).classList.add('correct-answer');\
        \}\
    \});\
\
    document.getElementById('scoreText').textContent = `Score: $\{score\} / $\{quizData.length\}`;\
    document.getElementById('progressFill').style.width = '100%';\
    document.getElementById('progressText').textContent = '100% complete';\
\
    // Results panel\
    const pct = Math.round((score / quizData.length) * 100);\
    let emoji = pct >= 90 ? '\uc0\u55356 \u57119 ' : pct >= 70 ? '\u55357 \u56397 ' : pct >= 50 ? '\u55357 \u56538 ' : '\u55357 \u56490 ';\
    let msg = pct >= 90 ? '\'a1Excelente! You\\'re ready for the exam!' :\
              pct >= 70 ? '\'a1Muy bien! Review the ones you missed.' :\
              pct >= 50 ? 'Good effort! Keep studying the vocabulary.' :\
              'Keep practicing \'97 you\\'ll get there! \'a1T\'fa puedes!';\
\
    let catHTML = '';\
    for (const [cat, data] of Object.entries(catScores)) \{\
        catHTML += `<div class="cat-card">\
            <div class="cat-name">$\{cat\}</div>\
            <div class="cat-score">$\{data.correct\}/$\{data.total\}</div>\
        </div>`;\
    \}\
\
    const panel = document.getElementById('resultsPanel');\
    panel.innerHTML = `\
        <h2>$\{emoji\} Results</h2>\
        <div class="big-score">$\{pct\}%</div>\
        <div class="message">$\{score\} out of $\{quizData.length\} correct \'97 $\{msg\}</div>\
        <div class="category-scores">$\{catHTML\}</div>\
        <button class="btn" onclick="resetQuiz()" style="margin-top:20px;">\uc0\u55357 \u56580  Try Again</button>\
    `;\
    panel.style.display = 'block';\
\
    document.getElementById('btnContainer').style.display = 'none';\
    panel.scrollIntoView(\{ behavior: 'smooth' \});\
\}\
\
function resetQuiz() \{\
    submitted = false;\
    userAnswers = new Array(quizData.length).fill(-1);\
    document.getElementById('resultsPanel').style.display = 'none';\
    document.getElementById('btnContainer').style.display = 'block';\
    document.getElementById('scoreText').textContent = 'Score: 0 / 60';\
    document.getElementById('progressFill').style.width = '0%';\
    document.getElementById('progressText').textContent = '0% complete';\
    buildQuiz();\
    window.scrollTo(\{ top: 0, behavior: 'smooth' \});\
\}\
\
buildQuiz();\
</script>\
\
</body>\
</html>}